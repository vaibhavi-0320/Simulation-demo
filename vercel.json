{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "frontend/api/*.ts": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/stellar/build",
      "destination": "/frontend/api/stellar-build"
    },
    {
      "source": "/api/stellar/submit",
      "destination": "/frontend/api/stellar-submit"
    },
    {
      "source": "/api/stellar/build-simulation",
      "destination": "/frontend/api/stellar-build-simulation"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

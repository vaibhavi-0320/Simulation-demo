# Environment Configuration
# Copy this file to .env and fill in your values

# Application Environment
NODE_ENV=development
SECURITY_RELAXED_LOCAL=false
VITE_SECURITY_RELAXED_LOCAL=false

# Server Configuration
PORT=4517
APP_PORT=4517
APP_ORIGIN=http://127.0.0.1:4517,https://your-production-domain.vercel.app
FORCE_HTTPS=true

# Authentication (Clerk)
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_ADMIN_USER_IDS=user_123,user_456
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Blockchain (Stellar/Soroban)
SOROBAN_CONTRACT_ADDRESS=your_deployed_contract_address_here
VITE_STELLAR_CONTRACT_ID=your_soroban_contract_id_here
VITE_API_BASE=
FINTRIX_ESCROW_ADDRESS=your_testnet_escrow_public_key_here
ESCROW_DESTINATION=your_testnet_escrow_public_key_here
USD_PER_XLM=25

# Caching (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info
